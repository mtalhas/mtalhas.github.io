---
import Base from '../../layouts/Base.astro';
const cspExtra = "connect-src 'self'";
---
<Base
  title="MCPMeter"
  description="Estimate token cost per turn of your MCP setup. Runs in your browser."
  cspExtra={cspExtra}
  noAnalytics={true}
>
  <section class="container stack" data-island="mcpmeter">
    <h1>MCPMeter</h1>
    <p>Paste your <code>claude_desktop_config.json</code> or a generic server list. We estimate input-side tokens added per turn.</p>

    <p data-test="stale-banner" role="status" class="muted" style="display:none; padding:0.5rem; border:1px solid var(--border); border-radius:8px;"></p>

    <label for="cfg">Config</label>
    <textarea
      id="cfg"
      data-test="config"
      rows="12"
      style="width:100%"
      placeholder={'{"mcpServers": {"filesystem": {"command": "npx", "args": ["@modelcontextprotocol/server-filesystem", "/path"]}}}'}
      aria-label="MCP config JSON"
    ></textarea>

    <p>
      <label for="variant">Badge style </label>
      <select id="variant" data-test="variant">
        <option value="numeric">Numeric</option>
        <option value="percentile">Percentile vs community</option>
        <option value="compare">Comparison vs median</option>
      </select>
      <button data-test="run" class="cta">Estimate</button>
    </p>

    <table aria-label="Per-server token estimate">
      <thead>
        <tr>
          <th>Server</th>
          <th>Tools</th>
          <th>Tokens</th>
          <th>USD/turn</th>
          <th>Confidence</th>
        </tr>
      </thead>
      <tbody data-test="tbody"></tbody>
    </table>

    <p>
      Total tokens: <strong data-test="total-tokens">0</strong>
      &nbsp; Total cost per turn: <strong data-test="total-usd">$0.0000</strong>
    </p>

    <div data-test="badge" aria-label="Share badge" style="margin: 1rem 0"></div>

    <label for="perma">Share permalink (re-renders from URL hash, no server storage)</label>
    <input id="perma" data-test="permalink" type="text" style="width:100%" readonly aria-label="Permalink" />
  </section>

  <script>
    import { mount } from '../../islands/McpmeterApp';
    const root = document.querySelector('[data-island=mcpmeter]');
    if (root) mount(root as HTMLElement);
  </script>
</Base>
